# لوحة الإدارة - Servy Admin

# المنفذ المحلي
PORT=2026

# تفعيل API الحقيقي (false = بيانات حقيقية من الباك إند)
REACT_APP_USE_MOCK_API=false

# عنوان الـ API
# للتطوير مع proxy (يتجنب CORS):
# REACT_APP_API_BASE_URL=/servy/api/v1
# أو استخدم الرابط الكامل مباشرة:
REACT_APP_API_BASE_URL=https://souq-917s.onrender.com/servy/api/v1
REACT_APP_PROXY_TARGET=https://souq-917s.onrender.com

# اختياري: وقت الانتظار بالميلي ثانية (افتراضي 60000)
# REACT_APP_API_TIMEOUT=60000

# WebSocket طلبات حية (P2 — فعّله لما الباك يجهّز /ws/orders)
# REACT_APP_ENABLE_LIVE_WS=true
